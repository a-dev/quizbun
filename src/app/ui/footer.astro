---
import { VoicePicker } from "./voice-picker";
---

<footer>
  <div class="wrapper">
    <div class="content">
      <div class="meta">
        <div>MIT License, {new Date().getFullYear()}</div>
        <span class="item">
          <span>•</span>
          built by{" "}
          <a href="https://github.com/a-dev" target="_blank" class="link"
            >@a-dev</a
          >
        </span>
        <span class="item">
          <span>•</span>
          <svg width="14" height="14" fill="var(--color-text-on-main-bg-dark)" aria-hidden="true" class="octicon octicon-mark-github" viewBox="0 0 16 16"><path d="M8 0c4.42 0 8 3.58 8 8a8.01 8.01 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27s-1.36.09-2 .27c-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8"/></svg>
          <a class="link" target="_blank" href="https://github.com/a-dev/quizbun">
            quizbun</a
          >
        </span>
      </div>
      <VoicePicker client:idle />
    </div>
  </div>
</footer>
<style>
  .wrapper{
    container: footer / inline-size;

    max-width: var(--max-content-width);
    min-height: 3rem;
    margin: 0 auto;
    padding-block: 1.1rem;
    padding-inline: 1.5rem;
  }


  .content {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: var(--fs-xs);
  }

  @container footer (min-width: 40rem) {
    .content {
      justify-content: space-between;
    }
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    align-items: center;

    font-size: var(--fs-xs);
    font-weight: var(--fw-medium);
    line-height: var(--lh-s);
    color: var(--color-text-on-main-bg-dark);
  }

  .link {
    color: var(--color-focus-ring-on-main-bg-dark);
    text-decoration: none;
  }

  .item {
    display: flex;
    gap: 0.2rem;
    align-items: center;
  }
</style>
