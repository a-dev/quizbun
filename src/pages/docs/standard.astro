---
import { loadDoc } from "@/shared/lib/docs";
import { withBase } from "@/shared/lib/routing";
import DocsLayout from "@/app/docs-layout.astro";

const doc = loadDoc("docs/standard.md");
---

<DocsLayout
  title="Quiz Object Standard"
  description="The normative reference for Quizbun's versioned JSON quiz format: fields, rules, correctness model, and versioning policy."
>
  <Fragment set:html={doc.html} />

  <h2 id="related-resources">Related resources</h2>
  <ul>
    <li>
      <a href={withBase("schema/quiz.v1.json")}
        >Published JSON Schema (<code>quiz.v1.json</code>)</a
      >
      — the generated artifact for editors, validators, and AI tools.
    </li>
    <li>
      <a href={withBase("docs/examples/")}>Canonical example quizzes</a> — one valid
      quiz per question shape, ready to copy.
    </li>
    <li>
      <a href={withBase("docs/prompt/")}>AI generation prompt</a> — the schema
      and an example packaged as a single copyable prompt.
    </li>
  </ul>
</DocsLayout>
