{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist", "tmp", "storybook-static"],
  "compilerOptions": {
    "types": ["bun"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "verbatimModuleSyntax": true,
    "paths": {
      "@/*": ["./src/*"],
      "#styles": ["./src/shared/styles/index"],
      "#styles/*": ["./src/shared/styles/*"],
      "#storybook/*": ["./.storybook/*"]
    }
  }
}
